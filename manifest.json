{
  "manifest_version": 3,
  "name": "Google Chat Pinned Chats",
  "version": "1.0.1",
  "description": "Pin specific chats to a persistent section at the top of Google Chat's sidebar.",
  "permissions": ["storage"],
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://chat.google.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
